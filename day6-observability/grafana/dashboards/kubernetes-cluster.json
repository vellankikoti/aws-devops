{
  "dashboard": {
    "title": "Kubernetes Cluster",
    "panels": [
      { "title": "Node Count", "type": "stat", "targets": [{ "expr": "count(kube_node_info)" }] },
      { "title": "Pod Status", "type": "piechart", "targets": [{ "expr": "sum(kube_pod_status_phase) by (phase)" }] },
      { "title": "Container Restarts", "type": "timeseries", "targets": [{ "expr": "sum(rate(kube_pod_container_status_restarts_total[15m])) by (pod)" }] }
    ]
  }
}
