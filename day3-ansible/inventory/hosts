# =============================================================================
# Static Inventory - Update with your EC2 IPs
# =============================================================================
# Replace <EC2_PUBLIC_IP> with your actual EC2 instance IP

[webservers]
web1 ansible_host=<EC2_PUBLIC_IP>

[databases]
# RDS is managed by AWS - no SSH access needed

[monitoring]
# Same as webservers for now
web1 ansible_host=<EC2_PUBLIC_IP>

[all:vars]
ansible_user=ec2-user
ansible_ssh_private_key_file=~/.ssh/sockshop-key.pem
ansible_python_interpreter=/usr/bin/python3
project_name=sockshop
environment=dev
